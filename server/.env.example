# Server Environment Variables
# Copy this file to .env and update with your values

# Server Configuration
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# CORS Configuration
# Set this to your deployed frontend URL
CLIENT_URL=https://your-frontend-domain.com

# JWT Configuration
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_ISSUER=ai-code-debugger

# OpenRouter AI Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://your-frontend-domain.com
OPENROUTER_APP_NAME=AI Code Debugger

# MongoDB Configuration
MONGODB_URI=mongodb+srv://your_username:your_url_encoded_password@cluster0.xxxxx.mongodb.net/ai-code-debugger?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=ai-code-debugger

# Atlas example:
# MONGODB_URI=mongodb+srv://your_username:your_url_encoded_password@cluster0.xxxxx.mongodb.net/ai-code-debugger?retryWrites=true&w=majority&appName=Cluster0
