{
  "name": "ai-code-debugger",
  "private": true,
  "version": "1.0.0",
  "description": "Full-stack starter project for AI Code Debugger",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "install:all": "npm --prefix server install && npm --prefix client install",
    "postinstall": "npm run install:all",
    "build": "npm --prefix client run build",
    "start": "npm --prefix server run start"
  },
  "devDependencies": {
    "localtunnel": "^2.0.2",
    "ngrok": "^5.0.0-beta.2"
  }
}
